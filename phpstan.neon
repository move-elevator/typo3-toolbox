includes:
	- %rootDir%/../../konradmichalik/phpstan-typo3-preset/phpstan.neon.dist
	- phpstan-baseline.neon

parameters:
	level: 6

	paths:
		- Classes
		- Configuration
		- Resources

	excludePaths:
		- .Build (?)

	typo3:
		requestGetAttributeMapping:
			routing: 'TYPO3\CMS\Backend\Routing\RouteResult'
