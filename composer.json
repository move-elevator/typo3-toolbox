{
	"name": "move-elevator/typo3-toolbox",
	"description": "A TYPO3 toolbox so handy, it makes even missing plugins feel insecure.",
	"license": "GPL-2.0-or-later",
	"type": "typo3-cms-extension",
	"require": {
		"php": "^8.4",
		"ext-intl": "*",
		"doctrine/dbal": "^4.4",
		"networkteam/sentry-client": "^6.0",
		"psr/http-factory": "^1.1",
		"psr/http-message": "^2.0",
		"psr/http-server-handler": "^1.0",
		"psr/http-server-middleware": "^1.0",
		"psr/log": "^3.0",
		"typo3/cms-adminpanel": "^14.3",
		"typo3/cms-backend": "^14.3",
		"typo3/cms-core": "^14.3",
		"typo3/cms-frontend": "^14.3",
		"typo3/cms-linkvalidator": "^14.3",
		"typo3fluid/fluid": "^5.3"
	},
	"require-dev": {
		"captainhook/captainhook": "^5.29",
		"eliashaeussler/version-bumper": "^3.2",
		"helhum/typo3-console": "^8.3",
		"move-elevator/composer-translation-validator": "^1.4",
		"typo3/cms-base-distribution": "^14.3",
		"typo3/cms-lowlevel": "^14.3"
	},
	"autoload": {
		"psr-4": {
			"MoveElevator\\Typo3Toolbox\\": "Classes"
		}
	},
	"config": {
		"allow-plugins": {
			"eliashaeussler/version-bumper": true,
			"ergebnis/composer-normalize": true,
			"move-elevator/composer-translation-validator": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		}
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "typo3_toolbox"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@cgl install"
		],
		"cgl": "@composer -d Tests/CGL --"
	}
}
